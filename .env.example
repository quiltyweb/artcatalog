# Shopify credentials. Duplicate this file as:
#   .env.development  -> dev store (used by `gatsby develop`) // DEV store credentials
#
# Get these from the Shopify admin of the target store:
#   Admin token:      Admin API access token
#   Storefront token: Storefront API access token
#   App ID:           the handle of the custom app (used as salesChannel)
#   Store domain:     <store-name>.myshopify.com

GATSBY_SHOPIFY_STOREFRONT_PASSWORD=shpat_xxx
GATSBY_SHOPIFY_ADMIN_PASSWORD=shpat_xxx
GATSBY_SHOPIFY_APP_ID=your-app-handle
GATSBY_SHOPIFY_STORE_DOMAIN='your-dev-store.myshopify.com'

# Optional
SENTRY_DSN=